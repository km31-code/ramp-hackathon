# Server-only. Never prefix this with NEXT_PUBLIC_.
OPENAI_API_KEY=

# Pick and pin a current text model before demo day.
OPENAI_MODEL=

# Keep the starter deterministic until the engine lane is ready.
HEIST_MODE=mock

# Optional: open a real GitHub PR during the Round 3 finale.
# Without these, the demo shows a rendered diff preview and never fails.
GITHUB_TOKEN=
GITHUB_REPO=km31-code/ramp-hackathon
