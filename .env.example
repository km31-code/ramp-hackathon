# Server-only. Never prefix this with NEXT_PUBLIC_.
OPENAI_API_KEY=

# Pick and pin a current Structured Outputs-capable text model before demo day.
# Example only; choose a model enabled for your OpenAI project.
OPENAI_MODEL=gpt-4o-mini

# Mock is deterministic and needs no network. Live fails safely to the visible fallback.
HEIST_MODE=mock
