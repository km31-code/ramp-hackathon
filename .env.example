# Server-only. Never prefix this with NEXT_PUBLIC_.
OPENAI_API_KEY=

# Current balanced GPT-5.6 tier. Supports Responses API streaming and Structured Outputs.
OPENAI_MODEL=gpt-5.6-terra

# Mock is deterministic and needs no network. Live fails safely to the visible fallback.
HEIST_MODE=mock

# Stripe Test Mode secret key (sk_test_...). Logs APPROVED breaches as PaymentIntents.
# Never commit real keys. Never prefix with NEXT_PUBLIC_.
STRIPE_SECRET_KEY=
